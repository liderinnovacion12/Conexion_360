# ============================================================
# Conexión 360 · Variables de entorno (ejemplo)
# Copia este archivo como `.env` y completa los valores reales.
# NUNCA subas el archivo `.env` al repositorio.
# ============================================================

# --- Supabase (autenticación, base de datos y storage) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# --- Storage / Buckets ---
VITE_SUPABASE_DOCS_BUCKET=documentos
VITE_SUPABASE_MEDIA_BUCKET=media

# --- SOLO SERVIDOR (api/admin-update-user.js) ---
# Sin prefijo VITE_ a propósito: así Vite nunca las incluye en el bundle
# del navegador. Configúralas en Vercel (Project Settings > Environment
# Variables), NUNCA las pongas en el .env que corre en el navegador.
# La service role key se obtiene en Supabase Dashboard > Project Settings > API.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- SOLO SERVIDOR (api/send-approval-email.js) ---
# API key de tu cuenta de Resend (https://resend.com), para el correo
# real de "tu proceso ha sido aprobado" al aspirante. Nunca con prefijo VITE_.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (opcional). Si lo omites, se usa el
# remitente de pruebas de Resend (onboarding@resend.dev), válido solo
# para pruebas, no para producción real.
RESEND_FROM="Conexión 360 <notificaciones@tudominio.co>"

# --- Integración futura: Anthropic (asistente IA) ---
# La clave NUNCA debe exponerse en el cliente. Úsala solo desde un backend/edge function.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# --- Integración futura: Odoo ERP ---
VITE_ODOO_BASE_URL=https://tu-odoo.example.com
VITE_ODOO_DB=tu_db

# --- Configuración de la aplicación ---
VITE_APP_NAME=Conexión 360
VITE_APP_ENV=development
# Modo de datos: "mock" usa datos de ejemplo, "supabase" conecta al backend real
VITE_DATA_MODE=mock
# Minutos de inactividad antes del cierre de sesión automático
VITE_SESSION_TIMEOUT_MIN=30
